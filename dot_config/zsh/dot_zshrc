# alias .3='cd ../../..'
# alias .4='cd ../../../..'
# alias .5='cd ../../../../..'

# # Always mkdir a path (this doesn't inhibit functionality to make a single dir)
# alias mkdir='mkdir -p'

#  This is your file 
# Add your configurations here
# alias vim=nvim
alias cat=bat
alias copilot='gh copilot'
# eza aliases
alias ls='eza --color=always --group-directories-first --icons=always' # Preferred 'ls' implementation
alias la='eza -a --color=always --group-directories-first --icons=always'  # All files and dirs
alias ll='eza -l --color=always --group-directories-first --icons=always'  # Long format
alias lt='eza -aT --color=always --group-directories-first --icons=always' # Tree listing
alias ld='eza -lhD --icons=auto'                                       # long list dirs
alias l.='eza -ald --color=always --group-directories-first --icons=always .*' # Show only dotfiles
alias l='eza -lh --icons=auto'                                         # long list
# useless but useful aliases
alias ft=fastfetch
alias leet='nvim -c Leet'
alias archbtw=fastfetch
alias iusearchbtw=fastfetch
alias btw=fastfetch
alias backup="bash /home/binaryraptor/.local/bin/backup.sh"
alias restore="bash /home/binaryraptor/.local/bin/restore.sh"
alias kee="cat /home/binaryraptor/Documents/Private/Other\ files/config.txt | wl-copy"
alias kp="nvim ~/.config/hypr/keybindings.conf"
alias up="nvim ~/.config/hypr/userprefs.conf"
# alias nvim='nv-focus'

# export EDITOR=nvim
export EDITOR=nvim
export VISUAL=nvim
export JAVA_HOME="/usr/lib/jvm/java-26-openjdk"
export PATH="$JAVA_HOME/bin:$PATH"

function vi-yank-wl-copy {
    zle vi-yank
    echo -n "$CUTBUFFER" | wl-copy
}
zle -N vi-yank-wl-copy
bindkey -M vicmd 'y' vi-yank-wl-copy
unset -f command_not_found_handler # Uncomment to prevent searching for commands not found in package manager
# Disable the escape-based run-help widgets
bindkey -v
# bindkey -r '\e[h'
# bindkey -r '\eh'
# bindkey -r '\e'
# unalias run-help 2>/dev/null

unsetopt TRANSIENT_RPROMPT
RPROMPT=''
export PATH=$PATH:/home/binaryraptor/.spicetify
export PATH="$HOME/.npm-global/bin:$PATH"
