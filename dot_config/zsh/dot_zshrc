#  Aliases 
# Override aliases here in '$ZDOTDIR/.zshrc' (already set in .zshenv)

# # Helpful aliases
# alias c='clear'                                                        # clear terminal
alias un='sudo pacman -Rns'                                             # uninstall package
alias up='sudo pacman -Syu'                                             # update system/package/aur
alias pl='pacman -Qs'                                              # list installed package
alias pa='sudo pacman -Ss'                                              # list available package
alias pc='sudo pacman -Sc'                                              # remove unused cache
alias po='pacman -Qtdq | pacman -Rns -'                        # remove unused packages, also try > $aurhelper -Qqd | $aurhelper -Rsu --print -
# alias vc='code'                                                        # gui code editor
alias fastfetch='fastfetch --logo-type kitty'

# # Directory navigation shortcuts
